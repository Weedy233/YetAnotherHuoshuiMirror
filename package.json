{
  "name": "yet-another-huoshui-mirror",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "bun run --cwd apps/api dev",
    "dev:api:remote": "bun run --cwd apps/api dev:remote",
    "dev:api:local": "bun run --cwd apps/api dev:local",
    "dev:web": "cd apps/web && bun run dev",
    "build": "bun run --filter '*' build",
    "check": "bun run typecheck && bun run lint",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "deploy:api": "bun run --cwd apps/api deploy",
    "deploy:web": "bun run --cwd apps/web build && bunx wrangler pages deploy apps/web/dist --project-name huoshui-mirror-web",
    "deploy": "bun run deploy:api && bun run deploy:web",
    "dev:api:miniflare": "bun run --cwd apps/api dev:miniflare"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@cloudflare/workers-types": "4.20260702.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@vitest/coverage-v8": "4.1.9",
    "jsdom": "29.1.1",
    "typescript": "latest",
    "vitest": "4.1.9"
  },
  "dependencies": {
    "@types/node": "^26.1.1"
  }
}
